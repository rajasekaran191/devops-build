pipeline {
    agent any

    stages {

        // ---------------- Clone Repo ----------------
        stage('Clone Repo') {
            steps {
                git branch: 'main', url: 'https://github.com/rajasekaran191/devops-build.git'
            }
        }

        // ---------------- Build Docker Image ----------------
        stage('Build Docker Image') {
            steps {
                sh 'docker build -t rajasekaran191/dev:latest .'
                sh 'echo "Starting build process..."'
                sh 'docker push rajasekaran191/dev:latest'
                sh 'echo "Build and push completed!"'
            }
        }

        // ---------------- Push to DockerHub ----------------
        stage('Push to DockerHub') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'dockerhub-credentials',
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {
                    sh '''
                        echo $DOCKER_PASS | docker login -u $DOCKER_USER --password-stdin
                        echo "Starting deployment..."
                        # Pull latest production image
                        docker pull rajasekaran191/prod:latest
                        # Stop old container (if exists)
                        docker stop app-container || true
                        docker rm app-container || true
                        # Run new container
                        docker run -d -p 80:80 --name app-container rajasekaran191/prod:latest
                        echo "Deployment completed!"
                    '''
                }
            }
        }

    } // end of stages
    post {
        always {
            echo 'Cleaning up Docker login...'
            sh 'docker logout'
        }
        success {
            echo 'Pipeline completed successfully! Your new changes are live.'
        }
        failure {
            echo 'Pipeline failed. Check the logs above for errors.'
        }
    }
} // end of pipeline
